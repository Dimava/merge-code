{
  "name": "merge-code",
  "displayName": "Merge Code",
  "description": "Sublime Merge integration for VS Code",
  "version": "0.0.1",
  "publisher": "dimava",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["SCM Providers"],
  "activationEvents": ["*"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mergeCode.open",
        "title": "Merge Code: Open Repository"
      },
      {
        "command": "mergeCode.blame",
        "title": "Merge Code: Blame"
      },
      {
        "command": "mergeCode.fileHistory",
        "title": "Merge Code: File History"
      },
      {
        "command": "mergeCode.lineHistory",
        "title": "Merge Code: Line History"
      },
      {
        "command": "mergeCode.myCommits",
        "title": "Merge Code: Show My Commits"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "mergeCode.open",
          "when": "config.git.enabled && gitOpenRepositoryCount != 0"
        },
        {
          "command": "mergeCode.blame",
          "when": "config.git.enabled && gitOpenRepositoryCount != 0"
        },
        {
          "command": "mergeCode.fileHistory",
          "when": "config.git.enabled && gitOpenRepositoryCount != 0"
        },
        {
          "command": "mergeCode.lineHistory",
          "when": "config.git.enabled && gitOpenRepositoryCount != 0"
        },
        {
          "command": "mergeCode.myCommits",
          "when": "config.git.enabled && gitOpenRepositoryCount != 0"
        }
      ],
      "scm/title": [
        {
          "command": "mergeCode.open",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "mergeCode.open",
          "group": "mergeCode@1"
        },
        {
          "command": "mergeCode.blame",
          "group": "mergeCode@2"
        },
        {
          "command": "mergeCode.fileHistory",
          "group": "mergeCode@3"
        },
        {
          "command": "mergeCode.lineHistory",
          "group": "mergeCode@4",
          "when": "editorHasSelection"
        },
        {
          "command": "mergeCode.myCommits",
          "group": "mergeCode@5"
        }
      ]
    },
    "configuration": {
      "title": "Merge Code",
      "properties": {
        "mergeCode.smerge": {
          "type": "string",
          "default": "smerge",
          "description": "Path to Sublime Merge executable (smerge)"
        },
        "mergeCode.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show Sublime Merge status bar item with unstaged/staged counts"
        },
        "mergeCode.showBranchName": {
          "type": "boolean",
          "default": false,
          "description": "Show current branch name in status bar"
        }
      }
    }
  },
  "scripts": {
    "check": "oxfmt && oxlint && tsgo --noEmit",
    "compile": "tsgo -p ./",
    "watch": "tsgo -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.85.0",
    "@typescript/native-preview": "latest",
    "oxfmt": "latest",
    "oxlint": "latest"
  },
  "extensionDependencies": ["vscode.git"],
  "peerDependencies": {
    "typescript": "6.0.0-beta"
  }
}
